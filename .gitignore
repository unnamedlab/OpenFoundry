# Ignore only local and generated artifacts.
# Keep source, docs, lockfiles, static assets, and versioned generated specs.

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local environment / secrets
.env
.env.*
!.env.example
!.env.*.example
!.env.sample
!.env.*.sample
!.env.template
!.env.*.template
.direnv/

# Rust
target/
target-*/
**/*.rs.bk
*.profraw
*.profdata
*.profraw.zst
llvm-cov-target/
lcov.info
cobertura.xml

# Python (tooling under /tools)
__pycache__/
*.py[cod]

# Node / SvelteKit
node_modules/
.pnpm-store/
.npm/
.svelte-kit/
.vite/
apps/web/build/
coverage/
playwright-report/
test-results/
*.tsbuildinfo
.eslintcache
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Terraform local state
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Benchmarks and local runtime output
benchmarks/results/*
!benchmarks/results/.gitkeep
.openfoundry/
tmp/
temp/
.cache/
*.log
*.pid
*.seed
*.tmp
*.temp

# Intentionally kept in Git:
# - apps/web/static/generated/openapi/openfoundry.json
# - apps/web/static/generated/terraform/openfoundry-provider.json
# - infra/terraform/providers/openfoundry/provider.schema.json

# Local imported docs snapshot
docs_original_palantir_foundry/

# ArgoCD: real Slack creds (only the .example.yaml is checked in)
infra/argocd/notifications/slack-secret.yaml
/capabilities-snapshot

# Local-built tool binaries at repo root (built by `go build ./tools/<name>`)
/route-audit
/identity-federation-service
/sql-lint
/bus-allowlist
/data-residency

# `make tools` installs buf / golangci-lint / sqlc / gofumpt here
/bin/

# Local-built service binaries at the service root (same name as the dir).
# Built by `go build ./services/<svc>/cmd/<svc>` without -o.
/services/agent-runtime-service/agent-runtime-service
/services/ai-evaluation-service/ai-evaluation-service
/services/ai-sink/ai-sink
/services/application-composition-service/application-composition-service
/services/audit-compliance-service/audit-compliance-service
/services/audit-sink/audit-sink
/services/authorization-policy-service/authorization-policy-service
/services/cipher-service/cipher-service
/services/code-repository-review-service/code-repository-review-service
/services/compute-module-service/compute-module-service

# Claude Code local config / worktrees
.claude/
