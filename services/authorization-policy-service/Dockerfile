FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=authorization-policy-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p authorization-policy-service  && cp /workspace/target/docker-release/authorization-policy-service /tmp/authorization-policy-service  && strip /tmp/authorization-policy-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50093

COPY --from=builder /tmp/authorization-policy-service /usr/local/bin/authorization-policy-service
COPY --from=builder /workspace/services/authorization-policy-service/config ./config
EXPOSE 50093
CMD ["/usr/local/bin/authorization-policy-service"]
