FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=model-lifecycle-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p model-lifecycle-service  && cp /workspace/target/docker-release/model-lifecycle-service /tmp/model-lifecycle-service  && strip /tmp/model-lifecycle-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50126

COPY --from=builder /tmp/model-lifecycle-service /usr/local/bin/model-lifecycle-service
EXPOSE 50126
CMD ["/usr/local/bin/model-lifecycle-service"]
