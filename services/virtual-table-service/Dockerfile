FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3 cmake perl zlib-dev zstd-dev cyrus-sasl-dev linux-headers
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=virtual-table-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p virtual-table-service --features kafka-rdkafka  && cp /workspace/target/docker-release/virtual-table-service /tmp/virtual-table-service  && strip /tmp/virtual-table-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3 zlib zstd-libs cyrus-sasl

ENV HOST=0.0.0.0
ENV PORT=50089

COPY --from=builder /tmp/virtual-table-service /usr/local/bin/virtual-table-service
EXPOSE 50089
CMD ["/usr/local/bin/virtual-table-service"]
