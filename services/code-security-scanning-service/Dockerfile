FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=code-security-scanning-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p code-security-scanning-service  && cp /workspace/target/docker-release/code-security-scanning-service /tmp/code-security-scanning-service  && strip /tmp/code-security-scanning-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50154

COPY --from=builder /tmp/code-security-scanning-service /usr/local/bin/code-security-scanning-service
EXPOSE 50154
CMD ["/usr/local/bin/code-security-scanning-service"]
