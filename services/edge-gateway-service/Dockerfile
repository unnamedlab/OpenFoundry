# syntax=docker/dockerfile:1.7
# Auto-generated by tools/regenerate_service_dockerfiles.py
# Do not edit by hand - update the script and re-run it instead.

FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1


COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=edge-gateway-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p edge-gateway-service  && cp /workspace/target/docker-release/edge-gateway-service /tmp/edge-gateway-service  && strip /tmp/edge-gateway-service

FROM alpine:3.23 AS runtime
WORKDIR /workspace/services/edge-gateway-service

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=8080

COPY --from=builder /tmp/edge-gateway-service /usr/local/bin/edge-gateway-service
COPY --from=builder /workspace/services/edge-gateway-service/config ./config
EXPOSE 8080
CMD ["/usr/local/bin/edge-gateway-service"]
