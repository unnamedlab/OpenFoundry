{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping Flink JobManagers and TaskManagers (PrometheusReporter).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "version": "9.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {"type": "datasource", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "description": "Apache Flink jobs overview — uptime, checkpoints, savepoint age. Pairs with infra/observability/prometheus-rules/flink.yaml and the T15 maintenance jobs in infra/k8s/flink/maintenance/.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Flink CDC → Iceberg deployment",
      "url": "https://github.com/unnamedlab/OpenFoundry/blob/main/infra/k8s/flink/flinkdeployment-cdc-iceberg.yaml",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    },
    {
      "title": "PrometheusRules — flink.yaml",
      "url": "https://github.com/unnamedlab/OpenFoundry/blob/main/infra/observability/prometheus-rules/flink.yaml",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "options": {
        "mode": "markdown",
        "content": "## Flink jobs overview\n\nCovers the CDC → Iceberg streaming job and the T15 batch maintenance jobs (rewrite-data-files, expire-snapshots-and-orphans). Alerts in `flink.yaml` page on: JobManager down for 2 m, job uptime ≤ 0 for 5 m, > 3 failed checkpoints in 30 m, no completed checkpoint for 1 h, savepoint older than 24 h."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "JobManagers up",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(up{job=~\"flink.*\",flink_role=\"jobmanager\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Running jobs",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(flink_jobmanager_job_uptime > 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed checkpoints (30m)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(flink_jobmanager_job_numberOfFailedCheckpoints[30m])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 4}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Oldest savepoint age",
      "description": "T15 maintenance jobs need a savepoint < 24 h to resume cleanly.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "max(time() - flink_jobmanager_job_lastSavepointTimestamp / 1000)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 43200},
              {"color": "red", "value": 86400}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Job uptime (per job)",
      "description": "flink_jobmanager_job_uptime in ms. Drops to 0 mean the job is FAILED / CANCELED — paged by FlinkJobNotRunning.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 9},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "flink_jobmanager_job_uptime / 1000",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Time since last completed checkpoint",
      "description": "FlinkLastCheckpointStale pages when this exceeds 1 h (3 600 s).",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 9},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "time() - flink_jobmanager_job_lastCheckpointRestoreTimestamp / 1000",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "3600",
          "legendFormat": "alert threshold (1h)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 3600}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failed checkpoints (rolling 30m)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 18},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(flink_jobmanager_job_numberOfFailedCheckpoints[30m])",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "3",
          "legendFormat": "alert threshold (>3 in 30m)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 3}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latest savepoint age (per job)",
      "description": "FlinkSavepointAgeHigh pages when any job exceeds 24 h (86 400 s) — T15 maintenance assumes fresh savepoints.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 18},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "time() - flink_jobmanager_job_lastSavepointTimestamp / 1000",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "86400",
          "legendFormat": "alert threshold (24h)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 86400}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"]}
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["openfoundry", "flink", "iceberg", "data-plane"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Flink jobs overview",
  "uid": "flink-overview",
  "version": 1,
  "weekStart": ""
}
