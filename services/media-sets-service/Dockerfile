FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3 protobuf-dev
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1


COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=media-sets-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p media-sets-service  && cp /workspace/target/docker-release/media-sets-service /tmp/media-sets-service  && strip /tmp/media-sets-service

FROM alpine:3.23 AS runtime
WORKDIR /workspace/services/media-sets-service

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50156

COPY --from=builder /tmp/media-sets-service /usr/local/bin/media-sets-service
EXPOSE 50156
CMD ["/usr/local/bin/media-sets-service"]
