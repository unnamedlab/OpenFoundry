    "@types/node": "=25.6.0",
    "autoprefixer": "=10.5.0",
    "eslint": "=10.2.1",
    "eslint-plugin-svelte": "=3.17.1",
    "globals": "=17.5.0",
    "postcss": "=8.5.12",
    "svelte": "=5.55.5",
    "svelte-check": "=4.4.6",
