{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping Lakekeeper /metrics.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "version": "9.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {"type": "datasource", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "description": "Lakekeeper (Iceberg REST catalog) service overview — RED metrics + sqlx pool saturation. Pairs with infra/k8s/platform/observability/prometheus-rules/lakekeeper.yaml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "ADR-0008 — Iceberg REST catalog (Lakekeeper)",
      "url": "https://github.com/unnamedlab/OpenFoundry/blob/main/docs/architecture/adr/ADR-0008-iceberg-rest-catalog-lakekeeper.md",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    },
    {
      "title": "PrometheusRules — lakekeeper.yaml",
      "url": "https://github.com/unnamedlab/OpenFoundry/blob/main/infra/k8s/platform/observability/prometheus-rules/lakekeeper.yaml",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "options": {
        "mode": "markdown",
        "content": "## Lakekeeper service overview\n\nIceberg REST catalog (axum + sqlx). Alerts in `lakekeeper.yaml` page on: process down, 5xx > 1 % for 10 m, p99 latency > 500 ms for 10 m, sqlx pool ≥ 95 % saturated for 5 m. The Iceberg scan SLO (ADR-0012 §2.2) depends on this service staying healthy — saturation here propagates upstream to DataFusion."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Instances up",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(up{job=~\"lakekeeper.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 1},
              {"color": "green", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx rate (5m)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(http_requests_total{job=~\"lakekeeper.*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=~\"lakekeeper.*\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.005},
              {"color": "red", "value": 0.01}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p99 latency (5m, all routes)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=~\"lakekeeper.*\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.3},
              {"color": "red", "value": 0.5}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Request rate (5m)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(http_requests_total{job=~\"lakekeeper.*\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency p50 / p99 / p99.9 by route",
      "description": "Per-route percentiles. The LakekeeperRequestLatencyP99High alert pages on p99 > 500 ms sustained for 10 m.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 9},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.5, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=~\"lakekeeper.*\"}[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=~\"lakekeeper.*\"}[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.999, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=~\"lakekeeper.*\"}[5m])))",
          "legendFormat": "p99.9 {{route}}",
          "refId": "C"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "0.5",
          "legendFormat": "p99 alert threshold",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.5}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Status code mix (5m)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 9},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (status) (rate(http_requests_total{job=~\"lakekeeper.*\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "sqlx pool — connections (per instance)",
      "description": "LakekeeperDbPoolSaturated pages when idle == 0 AND acquired >= max × 0.95 for 5 m. A flat-line on idle is the leading signal.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 18},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sqlx_pool_connections_idle{job=~\"lakekeeper.*\"}",
          "legendFormat": "idle {{instance}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sqlx_pool_connections_acquired{job=~\"lakekeeper.*\"}",
          "legendFormat": "acquired {{instance}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sqlx_pool_connections_max{job=~\"lakekeeper.*\"}",
          "legendFormat": "max {{instance}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "sqlx pool saturation (max instance)",
      "description": "Acquired / max across all Lakekeeper instances; the alert threshold is 0.95.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 18},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "max(sqlx_pool_connections_acquired{job=~\"lakekeeper.*\"} / clamp_min(sqlx_pool_connections_max{job=~\"lakekeeper.*\"}, 1))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.8},
              {"color": "red", "value": 0.95}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["openfoundry", "lakekeeper", "iceberg", "data-plane"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
