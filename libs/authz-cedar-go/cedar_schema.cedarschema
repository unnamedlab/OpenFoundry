// OpenFoundry Cedar authorization schema.
//
// Derived from `libs/core-models` per ADR-0027:
//   * `User`       вЂ” caller identity (mirrors auth-middleware claims)
//   * `Marking`    вЂ” classification label (`core-models::MarkingId`)
//   * `Branch`     вЂ” dataset branch (`core-models::BranchName`)
//   * `Dataset`    вЂ” versioned dataset RID (`core-models::DatasetRid`)
//   * `Object`     вЂ” ontology object instance (`{type, id}`-keyed)
//   * `OntologyAction` вЂ” ontology action *type* that mutates `Object`s
//     (the entity is named `OntologyAction` because Cedar reserves the
//     bare `Action` identifier for its built-in action namespace).
//
// Entity attributes are intentionally narrow: we only materialise the
// fields that policies actually inspect today. New fields are additive
// вЂ” Cedar's schema validator rejects undeclared attributes, so adding
// one here means we can start writing policies against it immediately
// without touching the engine wrapper.
//
// Actions modeled (exhaustive вЂ” extend in lock-step with services):
//   * `read`            on `Object`, `Dataset`, `Branch`
//   * `write`           on `Object`, `Dataset`
//   * `delete`          on `Object`, `Dataset`
//   * `branch::create`  on `Dataset`
//   * `branch::merge`   on `Branch`
//   * `action::invoke`  on `OntologyAction` (ontology action types)
//
// `clearances` carries the *set of marking ids* the user is allowed to
// see; `markings` on a resource is the set of effective markings on
// that resource (direct + inherited). The canonical clearance check
// is therefore `principal.clearances.containsAll(resource.markings)`,
// which is what the default `forbid` policy in the bootstrap migration
// expresses.

entity Group = {
  "id": String,
};

entity Role = {
  "id": String,
};

entity User in [Group, Role] = {
  "tenant": String,
  "clearances": Set<Marking>,
  "roles": Set<String>,
  "project_scope_rids"?: Set<String>,
  "kind"?: String,
  "mfa_age_secs"?: Long,
};

entity Marking = {
  "name": String,
};

entity Branch in [Dataset] = {
  "name": String,
  "dataset_rid": String,
};

entity Dataset = {
  "rid": String,
  "tenant": String,
  "markings": Set<Marking>,
};

entity Object = {
  "type": String,
  "tenant": String,
  "markings": Set<Marking>,
};

entity OntologyAction = {
  "type": String,
  "tenant": String,
};

entity CipherKey = {
  "rid": String,
  "tenant": String,
  "markings": Set<Marking>,
};

// в”Ђв”Ђ Media sets (H3) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
//
// Mirrors `services/media-sets-service` row types. Fields:
//   * `tenant`             вЂ” caller tenant scope (matches User.tenant).
//   * `project_rid`        вЂ” Foundry project RID the set lives in.
//   * `transaction_policy` вЂ” `TRANSACTIONLESS` | `TRANSACTIONAL`.
//   * `virtual`            вЂ” true when the set is virtual (bytes stay
//                            in an external source).
//   * `markings`           вЂ” direct markings on the set. The
//                            application unions these into a child
//                            item's effective markings before invoking
//                            `media_item::*` so per-item policies see
//                            the full security envelope.
//
// `MediaItem in [MediaSet]` makes `it in MediaSet::"вЂ¦"` work in
// future policies that want to filter by parent set without an
// explicit attribute walk.

entity MediaSet = {
  "rid": String,
  "tenant": String,
  "project_rid": String,
  "transaction_policy": String,
  "virtual": Bool,
  "markings": Set<Marking>,
};

entity MediaItem in [MediaSet] = {
  "media_set_rid": String,
  "tenant": String,
  "mime_type": String,
  "size_bytes": Long,
  "markings": Set<Marking>,
};

action "read" appliesTo {
  principal: [User],
  resource:  [Object, Dataset, Branch],
};

action "write" appliesTo {
  principal: [User],
  resource:  [Object, Dataset],
};

action "delete" appliesTo {
  principal: [User],
  resource:  [Object, Dataset],
};

action "branch::create" appliesTo {
  principal: [User],
  resource:  [Dataset],
};

action "branch::merge" appliesTo {
  principal: [User],
  resource:  [Branch],
};

action "action::invoke" appliesTo {
  principal: [User],
  resource:  [OntologyAction],
};

action "cipher::encrypt" appliesTo {
  principal: [User],
  resource:  [CipherKey],
};

action "cipher::decrypt" appliesTo {
  principal: [User],
  resource:  [CipherKey],
};

action "cipher::manage" appliesTo {
  principal: [User],
  resource:  [CipherKey],
};

// в”Ђв”Ђ Media-set actions (H3) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

action "media_set::view" appliesTo {
  principal: [User],
  resource:  [MediaSet],
};

action "media_set::manage" appliesTo {
  principal: [User],
  resource:  [MediaSet],
};

action "media_set::delete" appliesTo {
  principal: [User],
  resource:  [MediaSet],
};

action "media_item::read" appliesTo {
  principal: [User],
  resource:  [MediaItem],
};

action "media_item::write" appliesTo {
  principal: [User],
  resource:  [MediaItem],
};

action "media_item::delete" appliesTo {
  principal: [User],
  resource:  [MediaItem],
};

// в”Ђв”Ђ Virtual-table actions (D1.1.9 P3) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
//
// Foundry doc В§ "Set up a connection for a virtual table" governs
// these resources. The clearance floor (markings inherited from the
// source) is enforced at register-time by virtual-table-service вЂ”
// Cedar adds the per-action authorisation layer on top.
//
// Capabilities are mirrored on the entity (read/write/incremental/
// versioning/compute_pushdown) so a policy can gate
// `virtual_table::write_data` on `resource.capabilities.write == true`
// without a network hop into the capability matrix.

entity VirtualTable = {
  "rid": String,
  "source_rid": String,
  "project_rid": String,
  "provider": String,
  "table_type": String,
  "markings": Set<Marking>,
  "capabilities": {
    "read": Bool,
    "write": Bool,
    "incremental": Bool,
    "versioning": Bool,
  },
};

action "virtual_table::view" appliesTo {
  principal: [User],
  resource:  [VirtualTable],
};

action "virtual_table::register" appliesTo {
  principal: [User],
  resource:  [VirtualTable],
};

action "virtual_table::delete" appliesTo {
  principal: [User],
  resource:  [VirtualTable],
};

action "virtual_table::write_data" appliesTo {
  principal: [User],
  resource:  [VirtualTable],
};

action "virtual_table::manage_markings" appliesTo {
  principal: [User],
  resource:  [VirtualTable],
};

action "virtual_table::import_to_project" appliesTo {
  principal: [User],
  resource:  [VirtualTable],
};

// в”Ђв”Ђ Schedule + ServicePrincipal (P3 of pipeline-schedule-service) в”Ђ
//
// Introduces `Project`, `Schedule`, `PipelineBuildTarget` resources,
// and a `ServicePrincipal` principal type used by project-scoped
// schedules per the Foundry doc В§ "Project scope". Policies inspect:
//   * `User.roles` to gate edit / pause-resume / convert flows;
//   * `ServicePrincipal.project_scope_rids` (Set<String>) so the
//     dispatch action can confirm the principal is bound to the
//     pipeline's project.

entity Project = {
  "rid": String,
  "tenant": String,
};

entity ServicePrincipal = {
  "rid": String,
  "tenant": String,
  "project_scope_rids": Set<String>,
  "clearances": Set<Marking>,
};

entity Schedule = {
  "rid": String,
  "tenant": String,
  "project_rid": String,
  "scope_kind": String,
  "owner_id": String,
};

entity PipelineBuildTarget = {
  "pipeline_rid": String,
  "project_rid": String,
  "tenant": String,
  "markings": Set<Marking>,
};

action "schedule::edit" appliesTo {
  principal: [User],
  resource:  [Schedule],
};

action "schedule::pause_resume" appliesTo {
  principal: [User],
  resource:  [Schedule],
};

action "schedule::convert_to_project_scope" appliesTo {
  principal: [User],
  resource:  [Schedule],
};

action "build::run" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [PipelineBuildTarget],
};

// в”Ђв”Ђ Identity-federation admin (S3.1.i) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
//
// Resources owned by `identity-federation-service` admin endpoints.
// `Group` and `Role` (declared above User) act as parent UIDs for
// `principal in Group::"вЂ¦"` / `Role::"вЂ¦"` checks emitted by the
// service's bundled `policies/identity_admin.cedar` set.

entity JwksKey = {
  "kid": String,
  "status": String,
};

entity ScimUser = {
  "id": String,
};

entity ScimGroup = {
  "id": String,
};

action "rotate_jwks" appliesTo {
  principal: [User],
  resource:  [JwksKey],
};

action "retire_jwks" appliesTo {
  principal: [User],
  resource:  [JwksKey],
};

action "scim_provision_user" appliesTo {
  principal: [User],
  resource:  [ScimUser],
};

action "scim_deprovision_user" appliesTo {
  principal: [User],
  resource:  [ScimUser],
};

action "scim_provision_group" appliesTo {
  principal: [User],
  resource:  [ScimGroup],
};

// в”Ђв”Ђ Iceberg REST Catalog (D1.1.8 P3) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
//
// `iceberg-catalog-service` exposes Apache Iceberg REST Catalog
// endpoints that external clients (PyIceberg, Spark, Trino, Snowflake)
// hit directly. Authorization wraps every spec endpoint:
//
//   * Bearer / OAuth2 tokens minted by the catalog identify the
//     caller as either a [`User`] (long-lived API token) or a
//     [`ServicePrincipal`] (OAuth2 client_credentials grant).
//   * Resources are `IcebergNamespace` (a Foundry-scoped container)
//     and `IcebergTable` (the spec's table primitive).
//   * Markings inheritance: at table creation time the catalog
//     SNAPSHOTS the parent namespace's markings into the table row
//     (mirrors D1.1.4 P4 dataset inheritance). Later namespace
//     marking changes do *not* propagate retroactively вЂ” operators
//     must explicitly reapply via the table-level `manage_markings`
//     endpoint.
//   * `read_metadata` is permitted to anyone with `view`; the
//     metadata.json file does not contain row-level data so the
//     inherited clearance check is on the structural envelope only.
//   * `write_data` requires the principal to cover **every**
//     marking on the table (`clearances.containsAll(markings)`).

entity IcebergNamespace = {
  "rid": String,
  "tenant": String,
  "project_rid": String,
  "name": String,
  "markings": Set<Marking>,
};

entity IcebergTable in [IcebergNamespace] = {
  "rid": String,
  "tenant": String,
  "namespace_rid": String,
  "format_version": Long,
  "markings": Set<Marking>,
  "explicit_markings": Set<Marking>,
};

action "iceberg::namespace::view" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergNamespace],
};

action "iceberg::namespace::create" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergNamespace],
};

action "iceberg::namespace::drop" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergNamespace],
};

action "iceberg::namespace::update_properties" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergNamespace],
};

action "iceberg::namespace::manage_markings" appliesTo {
  principal: [User],
  resource:  [IcebergNamespace],
};

action "iceberg::table::view" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergTable],
};

action "iceberg::table::create" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergNamespace],
};

action "iceberg::table::drop" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergTable],
};

action "iceberg::table::write_data" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergTable],
};

action "iceberg::table::alter_schema" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergTable],
};

action "iceberg::table::read_metadata" appliesTo {
  principal: [User, ServicePrincipal],
  resource:  [IcebergTable],
};

action "iceberg::table::manage_markings" appliesTo {
  principal: [User],
  resource:  [IcebergTable],
};
