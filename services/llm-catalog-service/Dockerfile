# syntax=docker/dockerfile:1.7
# Auto-generated by tools/regenerate_service_dockerfiles.py
# Do not edit by hand - update the script and re-run it instead.

FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=llm-catalog-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p llm-catalog-service  && cp /workspace/target/docker-release/llm-catalog-service /tmp/llm-catalog-service  && strip /tmp/llm-catalog-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50095

COPY --from=builder /tmp/llm-catalog-service /usr/local/bin/llm-catalog-service
COPY --from=builder /workspace/services/llm-catalog-service/config ./config
EXPOSE 50095
CMD ["/usr/local/bin/llm-catalog-service"]
