# syntax=docker/dockerfile:1.7
# Auto-generated by tools/regenerate_service_dockerfiles.py
# Do not edit by hand - update the script and re-run it instead.

FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1


COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=lineage-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p lineage-service  && cp /workspace/target/docker-release/lineage-service /tmp/lineage-service  && strip /tmp/lineage-service

FROM alpine:3.23 AS runtime
WORKDIR /workspace/services/lineage-service

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50083

COPY --from=builder /tmp/lineage-service /usr/local/bin/lineage-service
COPY --from=builder /workspace/services/lineage-service/config ./config
EXPOSE 50083
CMD ["/usr/local/bin/lineage-service"]
