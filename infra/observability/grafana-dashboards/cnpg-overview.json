{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the CloudNativePG cluster sidecars.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "version": "9.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {"type": "datasource", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "description": "CloudNativePG cluster fleet overview — primary availability, replica lag, WAL archive health. Pairs with infra/observability/prometheus-rules/cnpg.yaml.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "ADR-0010 — CNPG Postgres operator",
      "url": "https://github.com/unnamedlab/OpenFoundry/blob/main/docs/architecture/adr/ADR-0010-cnpg-postgres-operator.md",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    },
    {
      "title": "PrometheusRules — cnpg.yaml",
      "url": "https://github.com/unnamedlab/OpenFoundry/blob/main/infra/observability/prometheus-rules/cnpg.yaml",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "options": {
        "mode": "markdown",
        "content": "## CloudNativePG cluster fleet\n\nOne CNPG `Cluster` per bounded context lives under `infra/k8s/cnpg/clusters/`. Alerts in `cnpg.yaml` page on: instance collector down for 2 m, no primary in a cluster for 1 m, replica WAL lag > 1 GiB for 5 m, switchover/failover events, WAL archive failures (PITR at risk)."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Clusters online",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(sum by (cluster) (cnpg_collector_up) > 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Clusters without a primary",
      "description": "Number of clusters whose primary collector is reporting down. The CnpgNoPrimary alert pages after 1 m.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(sum by (cluster) (cnpg_collector_up{role=\"primary\"}) == 0) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Max replica lag (5m max)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "max(max_over_time(cnpg_pg_replication_lag[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 536870912},
              {"color": "red", "value": 1073741824}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "WAL archive failures (15m)",
      "description": "CnpgWalArchiveFailing pages on any positive growth — PITR is degraded the moment this is non-zero.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 4},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(cnpg_pg_stat_archiver_failed_count[15m])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Replica lag (per cluster, max replica)",
      "description": "Max replica lag per CNPG cluster. The CnpgReplicaLagHigh alert threshold (1 GiB) is drawn in red.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 9},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "max by (cluster) (cnpg_pg_replication_lag)",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "1073741824",
          "legendFormat": "alert threshold (1 GiB)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1073741824}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Primary collector up (per cluster)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 9},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (cluster) (cnpg_collector_up{role=\"primary\"})",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Switchover / failover events (10m window)",
      "description": "Counts the number of times the primary identity changed in the last 10 m, per cluster. CnpgSwitchoverDetected fires for any non-zero value.",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 18},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (cluster) (changes(cnpg_collector_up{role=\"primary\"}[10m]))",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "WAL archive failure increase (15m)",
      "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 18},
      "targets": [
        {
          "datasource": {"type": "datasource", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (cluster) (increase(cnpg_pg_stat_archiver_failed_count[15m]))",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 2,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"]}
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["openfoundry", "cnpg", "postgres", "control-plane"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
        "current": {},
        "options": [],
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "CloudNativePG cluster fleet",
  "uid": "cnpg-overview",
  "version": 1,
  "weekStart": ""
}
