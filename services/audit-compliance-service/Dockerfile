# syntax=docker/dockerfile:1.7
# Auto-generated by tools/regenerate_service_dockerfiles.py
# Do not edit by hand - update the script and re-run it instead.

FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=audit-compliance-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p audit-compliance-service  && cp /workspace/target/docker-release/audit-compliance-service /tmp/audit-compliance-service  && strip /tmp/audit-compliance-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50115

COPY --from=builder /tmp/audit-compliance-service /usr/local/bin/audit-compliance-service
COPY --from=builder /workspace/services/audit-compliance-service/config ./config
EXPOSE 50115
CMD ["/usr/local/bin/audit-compliance-service"]
