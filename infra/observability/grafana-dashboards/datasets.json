{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping data-asset-catalog-service and dataset-versioning-service.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {"type": "datasource", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "type": "dashboard"
      }
    ]
  },
  "description": "Foundry datasets observability — transactions, view compute, branch fallbacks, marking enforcement, retention sweeps. Backed by metrics registered in services/data-asset-catalog-service and services/dataset-versioning-service (T8.1).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["datasets", "foundry", "openfoundry", "T8"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "${DS_PROMETHEUS}"},
        "hide": 0,
        "label": "Datasource",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "dataset_rid",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(dataset_transactions_open, dataset_rid)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "label": "Dataset RID",
        "sort": 1
      },
      {
        "name": "branch",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(dataset_transactions_open{dataset_rid=~\"$dataset_rid\"}, branch)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "label": "Branch",
        "sort": 1
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Datasets — Transactions, Views, Markings & Retention",
  "uid": "openfoundry-datasets",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Transactions",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Open transactions (current)",
      "description": "Sum across all (dataset_rid, branch) of `dataset_transactions_open`.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 5},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(dataset_transactions_open{dataset_rid=~\"$dataset_rid\", branch=~\"$branch\"})",
          "legendFormat": "open"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Open transactions per branch",
      "description": "Foundry guarantees ≤1 OPEN transaction per branch. Spikes indicate slow commits.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 6, "y": 1, "w": 12, "h": 5},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "dataset_transactions_open{dataset_rid=~\"$dataset_rid\", branch=~\"$branch\"}",
          "legendFormat": "{{dataset_rid}} / {{branch}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Aborted transactions (5m rate × 60s)",
      "description": "Sustained non-zero values usually indicate validation errors or client retries.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 5},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "60 * sum(rate(dataset_transactions_aborted_total[5m]))",
          "legendFormat": "aborted/min"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Committed transactions per type (rate)",
      "description": "`dataset_transactions_committed_total{type=…}` rate over 5m, grouped by Foundry transaction type.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"]}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (type) (rate(dataset_transactions_committed_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Aborted transactions (rate)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 7},
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dataset_transactions_aborted_total[5m]))",
          "legendFormat": "aborted/s"
        }
      ]
    },
    {
      "type": "row",
      "id": 7,
      "title": "View compute latency",
      "gridPos": {"x": 0, "y": 13, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "View compute duration — p50 / p95 / p99",
      "description": "`dataset_view_compute_duration_seconds` histogram quantiles. Spikes correlate with long branch histories or large APPEND chains.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 14, "w": 16, "h": 8},
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]}},
      "targets": [
        {
          "refId": "p50",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by (le) (rate(dataset_view_compute_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dataset_view_compute_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by (le) (rate(dataset_view_compute_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "View compute throughput (req/s)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 16, "y": 14, "w": 8, "h": 8},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dataset_view_compute_duration_seconds_count[5m]))",
          "legendFormat": "view computes/s"
        }
      ]
    },
    {
      "type": "row",
      "id": 10,
      "title": "Branch fallback resolution",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Branch fallback resolutions — hit vs miss",
      "description": "`dataset_branch_fallback_resolutions_total{outcome=hit|miss}` rate over 5m.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 23, "w": 16, "h": 7},
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"]}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (outcome) (rate(dataset_branch_fallback_resolutions_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Fallback hit ratio (5m)",
      "description": "hit / (hit + miss) over the last 5 minutes. NaN before any resolution lands.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 16, "y": 23, "w": 8, "h": 7},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.9}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "background", "graphMode": "none"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dataset_branch_fallback_resolutions_total{outcome=\"hit\"}[5m])) / clamp_min(sum(rate(dataset_branch_fallback_resolutions_total[5m])), 1e-9)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "type": "row",
      "id": 13,
      "title": "Marking enforcement",
      "gridPos": {"x": 0, "y": 30, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Marking enforcement denials (rate)",
      "description": "`dataset_marking_enforcement_denials_total` over 5m. Sustained denials may signal a misconfigured group / clearance.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 31, "w": 16, "h": 7},
      "fieldConfig": {"defaults": {"unit": "ops", "min": 0}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dataset_marking_enforcement_denials_total[5m]))",
          "legendFormat": "denials/s"
        }
      ]
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Total denials (24h)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 16, "y": 31, "w": 8, "h": 7},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(dataset_marking_enforcement_denials_total[24h]))",
          "legendFormat": "denials/24h"
        }
      ]
    },
    {
      "type": "row",
      "id": 16,
      "title": "Retention",
      "gridPos": {"x": 0, "y": 38, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Retention — files deleted (rate) & bytes freed (rate)",
      "description": "`dataset_retention_files_deleted_total` and `dataset_retention_bytes_freed_total` over 5m. Bytes plotted on the right Y axis.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 39, "w": 16, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "ops", "min": 0},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "bytes_freed/s"},
            "properties": [
              {"id": "unit", "value": "Bps"},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"]}},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dataset_retention_files_deleted_total[5m]))",
          "legendFormat": "files_deleted/s"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(dataset_retention_bytes_freed_total[5m]))",
          "legendFormat": "bytes_freed/s"
        }
      ]
    },
    {
      "id": 18,
      "type": "stat",
      "title": "Retention totals (24h)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 16, "y": 39, "w": 8, "h": 8},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "bytes freed (24h)"},
            "properties": [{"id": "unit", "value": "bytes"}]
          }
        ]
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "area"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(dataset_retention_files_deleted_total[24h]))",
          "legendFormat": "files deleted (24h)"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(increase(dataset_retention_bytes_freed_total[24h]))",
          "legendFormat": "bytes freed (24h)"
        }
      ]
    }
  ]
}
