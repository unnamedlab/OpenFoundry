# Vespa schema — `document`
#
# Hybrid retrieval schema for OpenFoundry's ontology + knowledge-base
# semantic-search surface (see `docs/ontology-building/semantic-search.md`).
#
# It supports three retrieval modes that can be combined at query time:
#
#   1. Lexical  — BM25 over `title` and `body`.
#   2. Semantic — approximate nearest-neighbour search over `embedding`
#                 (HNSW, cosine distance) at 768 dimensions, matching the
#                 default sentence-embedding providers wired in
#                 `services/ai-service/src/domain/rag/`.
#   3. Filtered — `tenant_id`, `org_id`, `marking` and `object_type` are
#                 attribute fields available for cheap WAND/match filters
#                 so visibility/policy can be enforced before ranking
#                 (see `propagación de markings por linaje` in checklist
#                 § 1.5.6).
#
# The default `hybrid` rank-profile fuses BM25 and cosine similarity with
# a weighted sum; `semantic` and `lexical` are also exposed for ablation.
#
schema document {

    document document {

        field id type string {
            indexing: summary | attribute
            attribute: fast-search
            rank: filter
        }

        field tenant_id type string {
            indexing: summary | attribute
            attribute: fast-search
            rank: filter
        }

        field org_id type string {
            indexing: summary | attribute
            attribute: fast-search
            rank: filter
        }

        # Object-type identifier from the ontology (e.g. "ontology.Customer").
        field object_type type string {
            indexing: summary | attribute
            attribute: fast-search
            rank: filter
        }

        # Security markings propagated through lineage.
        field marking type array<string> {
            indexing: summary | attribute
            attribute: fast-search
            rank: filter
        }

        field title type string {
            indexing: summary | index
            index: enable-bm25
            match: text
        }

        field body type string {
            indexing: summary | index
            index: enable-bm25
            match: text
        }

        field url type string {
            indexing: summary | attribute
        }

        field created_at type long {
            indexing: summary | attribute
            attribute: fast-search
        }

        field updated_at type long {
            indexing: summary | attribute
            attribute: fast-search
        }

        # Dense embedding for semantic recall.  768 dims matches the default
        # sentence-transformer in `libs/vector-store`.  HNSW index gives
        # sub-linear ANN with cosine distance.
        field embedding type tensor<float>(x[768]) {
            indexing: attribute | index
            attribute {
                distance-metric: angular
            }
            index {
                hnsw {
                    max-links-per-node: 16
                    neighbors-to-explore-at-insert: 200
                }
            }
        }
    }

    # Field-set so a single text query targets both BM25 fields.
    fieldset default {
        fields: title, body
    }

    # ── Rank profiles ───────────────────────────────────────────────────

    # Pure lexical baseline — useful for ablation and as a fallback when
    # the embedding provider is unavailable.
    rank-profile lexical {
        first-phase {
            expression: bm25(title) * 2.0 + bm25(body)
        }
        summary-features {
            bm25(title)
            bm25(body)
        }
    }

    # Pure semantic — cosine similarity over the query embedding only.
    rank-profile semantic {
        inputs {
            query(q) tensor<float>(x[768])
        }
        first-phase {
            expression: closeness(field, embedding)
        }
        summary-features {
            closeness(field, embedding)
        }
    }

    # Hybrid fusion — weighted sum of normalised BM25 and cosine.
    # Weights are exposed as ranking features so callers can tune at query
    # time (`ranking.features.query(alpha)=…`).
    rank-profile hybrid inherits semantic {
        inputs {
            query(q) tensor<float>(x[768])
            query(alpha) double
            query(beta) double
        }
        first-phase {
            expression {
                # Default weights (alpha=0.6, beta=0.4) tuned to favour
                # semantic recall while keeping lexical precision.
                if(query(alpha) == 0, 0.6, query(alpha)) * closeness(field, embedding) +
                if(query(beta)  == 0, 0.4, query(beta))  * (bm25(title) * 0.5 + bm25(body) * 0.5) / (1.0 + bm25(title) + bm25(body))
            }
        }
        second-phase {
            rerank-count: 100
            expression: firstPhase
        }
        summary-features {
            closeness(field, embedding)
            bm25(title)
            bm25(body)
        }
    }

    # Default profile = hybrid.
    rank-profile default inherits hybrid {}
}
