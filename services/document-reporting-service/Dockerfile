# syntax=docker/dockerfile:1.7
# Auto-generated by tools/regenerate_service_dockerfiles.py
# Do not edit by hand - update the script and re-run it instead.

FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1


COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=document-reporting-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p document-reporting-service  && cp /workspace/target/docker-release/document-reporting-service /tmp/document-reporting-service  && strip /tmp/document-reporting-service

FROM alpine:3.23 AS runtime
WORKDIR /app

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50102

COPY --from=builder /tmp/document-reporting-service /usr/local/bin/document-reporting-service
COPY --from=builder /workspace/services/document-reporting-service/config ./config
EXPOSE 50102
CMD ["/usr/local/bin/document-reporting-service"]
