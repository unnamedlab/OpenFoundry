FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=identity-federation-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p identity-federation-service  && cp /workspace/target/docker-release/identity-federation-service /tmp/identity-federation-service  && strip /tmp/identity-federation-service

FROM alpine:3.23 AS runtime
WORKDIR /workspace/services/identity-federation-service

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50051

COPY --from=builder /tmp/identity-federation-service /usr/local/bin/identity-federation-service
COPY --from=builder /workspace/services/identity-federation-service/config ./config
EXPOSE 50051
CMD ["/usr/local/bin/identity-federation-service"]
