FROM rust:1.95-alpine3.23 AS builder
WORKDIR /workspace

RUN apk add --no-cache build-base pkgconf openssl-dev ca-certificates python3
ENV PYO3_PYTHON=python3
ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
    --mount=type=cache,target=/workspace/target,id=tenancy-organizations-service-target,sharing=locked \
    cargo build --locked --profile docker-release -p tenancy-organizations-service  && cp /workspace/target/docker-release/tenancy-organizations-service /tmp/tenancy-organizations-service  && strip /tmp/tenancy-organizations-service

FROM alpine:3.23 AS runtime
WORKDIR /workspace/services/tenancy-organizations-service

RUN apk add --no-cache ca-certificates libgcc libstdc++ libssl3

ENV HOST=0.0.0.0
ENV PORT=50113

COPY --from=builder /tmp/tenancy-organizations-service /usr/local/bin/tenancy-organizations-service
COPY --from=builder /workspace/services/tenancy-organizations-service/config ./config
EXPOSE 50113
CMD ["/usr/local/bin/tenancy-organizations-service"]
